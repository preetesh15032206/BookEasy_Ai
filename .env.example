# APP_GEMINI_API_KEY: Required for Gemini AI API calls.
# Note: Ensure this is set securely in your environment.
APP_GEMINI_API_KEY="MY_GEMINI_API_KEY"

# Database Credentials
# For local preview, we use sqlite by default. Provide a Postgres URI string if preferred.
DATABASE_URL="sqlite::memory:"

# Pinecone
# You need to set up a Pinecone account and create an API key
PINECONE_API_KEY="MY_PINECONE_API_KEY"

# The deployment environment automatically injects this at runtime with the service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
