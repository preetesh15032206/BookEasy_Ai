# APP_GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
APP_GEMINI_API_KEY="MY_GEMINI_API_KEY"

# Database Credentials
# For local preview, we use sqlite by default. Users can provide a Postgres URI string if preferred.
DATABASE_URL="sqlite::memory:"

# Pinecone
# Users need to set up a Pinecone account and create an API key
PINECONE_API_KEY="MY_PINECONE_API_KEY"

# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
